    (function () {
        function setAttributionCookie(sourceName, data, expirationDays) {
            if (!data || !sourceName || typeof expirationDays !== 'number') return;

            data.time = new Date().toISOString();
            var cookieName = sourceName + '_data_cookie';
            var cookieValue = JSON.stringify(data);
            var maxAgeSeconds = expirationDays * 24 * 60 * 60;
            var cookieString = cookieName + '=' + encodeURIComponent(cookieValue) + '; max-age=' + maxAgeSeconds + '; path=/';

            if (window.location.hostname && window.location.hostname !== 'localhost') {
                var parts = window.location.hostname.split('.');
                var tld = parts[parts.length - 1];
                if (parts.length >= 2 && tld.length > 1) {
                    var domain = '.' + parts.slice(parts.length - 2).join('.');
                    cookieString += '; domain=' + domain;
                }
            }

            cookieString += '; SameSite=None; Secure';
            document.cookie = cookieString;
        }

        function captureAttributionFromUrl() {
            var search = window.location.search;
            if (!search) return;

            var urlParams = new URLSearchParams(search);
            var source = urlParams.get('source');

            if (source === 'simp_google_adwords') {
                var adwordsData = { source: 'google_adwords' };

                urlParams.forEach(function(value, key) {
                    if (key.indexOf('utm_') === 0 || key === 'gclid') {
                        adwordsData[key] = value;
                    }
                });

                setAttributionCookie('adwords', adwordsData, 14);
            }
        }

        captureAttributionFromUrl();
    })();

        document.addEventListener("DOMContentLoaded", function () {
          var redirectTimeSpan = document.getElementById("redirectTime");
          var counter = 10;

          function redirectToHomepage() {
            
              if (navigator.userAgent.toLowerCase().includes("mobile")) {
                window.location.href = "/m";
              } else {
                window.location.href = "/";
              }
            
          }

          if (redirectTimeSpan) {
            var interval = setInterval(function () {
              if (counter > 0) {
                redirectTimeSpan.innerText = --counter;
              } else {
                clearInterval(interval);
                redirectToHomepage();
              }
            }, 1000);
          }

          
          // Update button behavior for mobile users
          if (navigator.userAgent.toLowerCase().includes("mobile")) {
            var homepageLinks = document.getElementsByClassName("home-btn");
            for (let i = 0; i < homepageLinks.length; i++) {
              homepageLinks[i].onclick = function () {
                window.location.href = "/m";
              };
            }
          }
          
        });
